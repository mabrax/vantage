{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex app-server retained evidence",
  "oneOf": [
    {
      "$ref": "#/definitions/clientRecord"
    },
    {
      "$ref": "#/definitions/serverRecord"
    },
    {
      "$ref": "#/definitions/acceptanceSummary"
    }
  ],
  "definitions": {
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "safeString": {
      "type": "string",
      "not": {
        "pattern": "(^|[\\s\"'])/(Users|home)/[^/\\s]+"
      }
    },
    "pathPlaceholder": {
      "type": "string",
      "pattern": "^/redacted/path/[0-9a-f]{24}$"
    },
    "pathValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/pathPlaceholder"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/pathPlaceholder"
          }
        }
      ]
    },
    "accountIdentifierValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^account-[0-9a-f]{24}$"
        },
        {
          "type": "integer",
          "minimum": -562949953421312,
          "maximum": -281474976710657
        }
      ]
    },
    "accountEmailValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^account-[0-9a-f]{16}@redacted\\.invalid$"
        }
      ]
    },
    "nonSecretCredentialValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "safeValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "$ref": "#/definitions/safeString"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/safeValue"
          }
        },
        {
          "type": "object",
          "patternProperties": {
            "(^([Tt]oken|[Tt]okens)$|([Aa]ccess|[Rr]efresh|[Bb]earer|[Aa]uth|[Aa]uthentication|[Ii]d)[_-]?[Tt]okens?$|[Aa]pi[_-]?[Kk]eys?$|[Aa]uthorization$|[Cc]ookies?$|[Cc]redentials?$|[Pp]asswords?$|[Ss]ecrets?$)": {
              "$ref": "#/definitions/nonSecretCredentialValue"
            },
            "([Aa]ccount[Ii]d|[Aa]ccount[Uu]ser[Ii]d|[Uu]ser[Ii]d|[Oo]rganization[Ii]d)$": {
              "$ref": "#/definitions/accountIdentifierValue"
            },
            "[Ee]mail$": {
              "$ref": "#/definitions/accountEmailValue"
            },
            "([Cc]odex[Hh]ome|[Cc]wd|[Hh]ome[Pp]ath|[Ii]nstruction[Ss]ources|[Pp]ath|[Rr]epository[Pp]ath)$": {
              "$ref": "#/definitions/pathValue"
            }
          },
          "additionalProperties": {
            "$ref": "#/definitions/safeValue"
          }
        }
      ]
    },
    "schemaProof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "valid"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "valid": {
          "const": true
        }
      }
    },
    "nativeIds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threadId": {
          "type": "string",
          "minLength": 1
        },
        "turnId": {
          "type": "string",
          "minLength": 1
        },
        "itemId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recordBase": {
      "type": "object",
      "required": [
        "byteLength",
        "direction",
        "monotonicOffsetMs",
        "nativeIds",
        "observationIndex",
        "schema"
      ],
      "properties": {
        "byteLength": {
          "type": "integer",
          "minimum": 0
        },
        "direction": {
          "enum": [
            "client",
            "server"
          ]
        },
        "monotonicOffsetMs": {
          "type": "number",
          "minimum": 0
        },
        "nativeIds": {
          "$ref": "#/definitions/nativeIds"
        },
        "observationIndex": {
          "type": "integer",
          "minimum": 0
        },
        "schema": {
          "$ref": "#/definitions/schemaProof"
        }
      }
    },
    "clientRecord": {
      "allOf": [
        {
          "$ref": "#/definitions/recordBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "byteLength",
            "direction",
            "method",
            "monotonicOffsetMs",
            "nativeIds",
            "observationIndex",
            "schema"
          ],
          "properties": {
            "byteLength": {},
            "direction": {
              "const": "client"
            },
            "id": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "monotonicOffsetMs": {},
            "nativeIds": {},
            "observationIndex": {},
            "params": {
              "$ref": "#/definitions/safeValue"
            },
            "schema": {}
          }
        }
      ]
    },
    "classifiedEnvelope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind"
          ],
          "properties": {
            "error": {
              "$ref": "#/definitions/safeValue"
            },
            "id": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "kind": {
              "const": "response"
            },
            "result": {
              "$ref": "#/definitions/safeValue"
            }
          },
          "oneOf": [
            {
              "properties": {
                "result": {}
              },
              "required": [
                "result"
              ],
              "not": {
                "properties": {
                  "error": {}
                },
                "required": [
                  "error"
                ]
              }
            },
            {
              "properties": {
                "error": {}
              },
              "required": [
                "error"
              ],
              "not": {
                "properties": {
                  "result": {}
                },
                "required": [
                  "result"
                ]
              }
            }
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "method",
            "params"
          ],
          "properties": {
            "kind": {
              "const": "server-notification"
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "params": {
              "$ref": "#/definitions/safeValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind",
            "method",
            "params"
          ],
          "properties": {
            "id": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "kind": {
              "const": "server-request"
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "params": {
              "$ref": "#/definitions/safeValue"
            }
          }
        }
      ]
    },
    "serverRecord": {
      "allOf": [
        {
          "$ref": "#/definitions/recordBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "byteLength",
            "direction",
            "envelope",
            "monotonicOffsetMs",
            "nativeIds",
            "observationIndex",
            "schema",
            "wireIndex"
          ],
          "properties": {
            "byteLength": {},
            "direction": {
              "const": "server"
            },
            "envelope": {
              "$ref": "#/definitions/classifiedEnvelope"
            },
            "monotonicOffsetMs": {},
            "nativeIds": {},
            "observationIndex": {},
            "schema": {},
            "wireIndex": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "acceptanceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gates",
        "hashes",
        "lifecycle",
        "observationsMs",
        "platform",
        "recordedAt",
        "runId",
        "schemaVersion",
        "shutdown",
        "versions"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "recordedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
        },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "arch",
            "os"
          ],
          "properties": {
            "os": {
              "const": "darwin"
            },
            "arch": {
              "const": "aarch64"
            }
          }
        },
        "versions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "codex",
            "deno"
          ],
          "properties": {
            "deno": {
              "const": "2.9.3"
            },
            "codex": {
              "const": "0.145.0"
            }
          }
        },
        "hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "compatibility",
            "coverage",
            "generatedBundle",
            "transcript"
          ],
          "properties": {
            "compatibility": {
              "$ref": "#/definitions/hash"
            },
            "generatedBundle": {
              "$ref": "#/definitions/hash"
            },
            "coverage": {
              "$ref": "#/definitions/hash"
            },
            "transcript": {
              "$ref": "#/definitions/hash"
            }
          }
        },
        "observationsMs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "initializeToReady",
            "spawnToInitializeResponse",
            "stdinCloseToExit",
            "totalShutdown",
            "turnStartToCompleted",
            "turnStartToFirstEvent"
          ],
          "properties": {
            "spawnToInitializeResponse": {
              "type": "number",
              "minimum": 0
            },
            "initializeToReady": {
              "type": "number",
              "minimum": 0
            },
            "turnStartToFirstEvent": {
              "type": "number",
              "minimum": 0
            },
            "turnStartToCompleted": {
              "type": "number",
              "minimum": 0
            },
            "stdinCloseToExit": {
              "type": "number",
              "minimum": 0
            },
            "totalShutdown": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "completedItems",
            "stderrBytes",
            "stdoutLines",
            "terminalStatus",
            "threadId",
            "turnId"
          ],
          "properties": {
            "stdoutLines": {
              "type": "integer",
              "minimum": 0
            },
            "stderrBytes": {
              "type": "integer",
              "minimum": 0
            },
            "threadId": {
              "type": "string",
              "minLength": 1
            },
            "turnId": {
              "type": "string",
              "minLength": 1
            },
            "terminalStatus": {
              "const": "completed"
            },
            "completedItems": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "shutdown": {
          "type": "object",
          "required": [
            "escapedDescendantContainmentProven",
            "noObservedDescendantsRemain"
          ],
          "properties": {
            "noObservedDescendantsRemain": {
              "type": "boolean"
            },
            "escapedDescendantContainmentProven": {
              "type": "boolean"
            }
          }
        },
        "gates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authenticatedTurnCompleted",
            "coverageComplete",
            "escapedDescendantContainmentProven",
            "everyRetainedEnvelopeSchemaValid",
            "exactVersions",
            "generatedArtifactsMatch",
            "lifecycleOrdered",
            "noObservedDescendantsRemain"
          ],
          "properties": {
            "exactVersions": {
              "type": "boolean"
            },
            "generatedArtifactsMatch": {
              "type": "boolean"
            },
            "coverageComplete": {
              "type": "boolean"
            },
            "everyRetainedEnvelopeSchemaValid": {
              "type": "boolean"
            },
            "lifecycleOrdered": {
              "type": "boolean"
            },
            "authenticatedTurnCompleted": {
              "type": "boolean"
            },
            "noObservedDescendantsRemain": {
              "type": "boolean"
            },
            "escapedDescendantContainmentProven": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex app-server retained evidence",
  "oneOf": [
    {
      "$ref": "#/definitions/clientRecord"
    },
    {
      "$ref": "#/definitions/serverRecord"
    },
    {
      "$ref": "#/definitions/acceptanceSummary"
    }
  ],
  "definitions": {
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "safeString": {
      "type": "string",
      "not": {
        "pattern": "(^|[\\s\"'])/(Users|home)/[^/\\s]+"
      }
    },
    "pathPlaceholder": {
      "type": "string",
      "pattern": "^/redacted/path/[0-9a-f]{24}$"
    },
    "pathValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/definitions/pathPlaceholder"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/pathPlaceholder"
          }
        }
      ]
    },
    "accountIdentifierValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^account-[0-9a-f]{24}$"
        },
        {
          "type": "integer",
          "minimum": -562949953421312,
          "maximum": -281474976710657
        }
      ]
    },
    "accountEmailValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "pattern": "^account-[0-9a-f]{16}@redacted\\.invalid$"
        }
      ]
    },
    "nonSecretCredentialValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        }
      ]
    },
    "safeValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "$ref": "#/definitions/safeString"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/definitions/safeValue"
          }
        },
        {
          "type": "object",
          "patternProperties": {
            "(^([Tt]oken|[Tt]okens)$|([Aa]ccess|[Rr]efresh|[Bb]earer|[Aa]uth|[Aa]uthentication|[Ii]d)[_-]?[Tt]okens?$|[Aa]pi[_-]?[Kk]eys?$|[Aa]uthorization$|[Cc]ookies?$|[Cc]redentials?$|[Pp]asswords?$|[Ss]ecrets?$)": {
              "$ref": "#/definitions/nonSecretCredentialValue"
            },
            "([Aa]ccount[Ii]d|[Aa]ccount[Uu]ser[Ii]d|[Uu]ser[Ii]d|[Oo]rganization[Ii]d)$": {
              "$ref": "#/definitions/accountIdentifierValue"
            },
            "[Ee]mail$": {
              "$ref": "#/definitions/accountEmailValue"
            },
            "([Cc]odex[Hh]ome|[Cc]wd|[Hh]ome[Pp]ath|[Ii]nstruction[Ss]ources|[Pp]ath|[Rr]epository[Pp]ath)$": {
              "$ref": "#/definitions/pathValue"
            }
          },
          "additionalProperties": {
            "$ref": "#/definitions/safeValue"
          }
        }
      ]
    },
    "schemaProof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "valid"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "valid": {
          "const": true
        }
      }
    },
    "nativeIds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "threadId": {
          "type": "string",
          "minLength": 1
        },
        "turnId": {
          "type": "string",
          "minLength": 1
        },
        "itemId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "recordBase": {
      "type": "object",
      "required": [
        "byteLength",
        "direction",
        "monotonicOffsetMs",
        "nativeIds",
        "observationIndex",
        "schema"
      ],
      "properties": {
        "byteLength": {
          "type": "integer",
          "minimum": 0
        },
        "direction": {
          "enum": [
            "client",
            "server"
          ]
        },
        "monotonicOffsetMs": {
          "type": "number",
          "minimum": 0
        },
        "nativeIds": {
          "$ref": "#/definitions/nativeIds"
        },
        "observationIndex": {
          "type": "integer",
          "minimum": 0
        },
        "schema": {
          "$ref": "#/definitions/schemaProof"
        }
      }
    },
    "clientRecord": {
      "allOf": [
        {
          "$ref": "#/definitions/recordBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "byteLength",
            "direction",
            "method",
            "monotonicOffsetMs",
            "nativeIds",
            "observationIndex",
            "schema"
          ],
          "properties": {
            "byteLength": {},
            "direction": {
              "const": "client"
            },
            "id": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "monotonicOffsetMs": {},
            "nativeIds": {},
            "observationIndex": {},
            "params": {
              "$ref": "#/definitions/safeValue"
            },
            "schema": {}
          }
        }
      ]
    },
    "classifiedEnvelope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind"
          ],
          "properties": {
            "error": {
              "$ref": "#/definitions/safeValue"
            },
            "id": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "kind": {
              "const": "response"
            },
            "result": {
              "$ref": "#/definitions/safeValue"
            }
          },
          "oneOf": [
            {
              "properties": {
                "result": {}
              },
              "required": [
                "result"
              ],
              "not": {
                "properties": {
                  "error": {}
                },
                "required": [
                  "error"
                ]
              }
            },
            {
              "properties": {
                "error": {}
              },
              "required": [
                "error"
              ],
              "not": {
                "properties": {
                  "result": {}
                },
                "required": [
                  "result"
                ]
              }
            }
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "method",
            "params"
          ],
          "properties": {
            "kind": {
              "const": "server-notification"
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "params": {
              "$ref": "#/definitions/safeValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "kind",
            "method",
            "params"
          ],
          "properties": {
            "id": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "kind": {
              "const": "server-request"
            },
            "method": {
              "type": "string",
              "minLength": 1
            },
            "params": {
              "$ref": "#/definitions/safeValue"
            }
          }
        }
      ]
    },
    "serverRecord": {
      "allOf": [
        {
          "$ref": "#/definitions/recordBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "byteLength",
            "direction",
            "envelope",
            "monotonicOffsetMs",
            "nativeIds",
            "observationIndex",
            "schema",
            "wireIndex"
          ],
          "properties": {
            "byteLength": {},
            "direction": {
              "const": "server"
            },
            "envelope": {
              "$ref": "#/definitions/classifiedEnvelope"
            },
            "monotonicOffsetMs": {},
            "nativeIds": {},
            "observationIndex": {},
            "schema": {},
            "wireIndex": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "shutdownEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "containmentCapability",
        "diagnostics",
        "directExit",
        "drains",
        "escapedDescendantContainmentProven",
        "lineageEvents",
        "noObservedDescendantsRemain",
        "observedPids",
        "remainingPids",
        "rootIdentity",
        "signalPath",
        "timedOutStages",
        "timings"
      ],
      "properties": {
        "rootIdentity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "processGroupId",
            "rootPid",
            "sessionId"
          ],
          "properties": {
            "rootPid": {
              "type": "integer",
              "minimum": 1
            },
            "processGroupId": {
              "type": "integer",
              "minimum": 1
            },
            "sessionId": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "observedPids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "lineageEvents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "auditSessionId",
              "kind",
              "parentPid",
              "pid",
              "processGroupId"
            ],
            "properties": {
              "kind": {
                "const": "snapshot-observed"
              },
              "pid": {
                "type": "integer",
                "minimum": 1
              },
              "parentPid": {
                "type": "integer",
                "minimum": 0
              },
              "processGroupId": {
                "type": "integer",
                "minimum": 1
              },
              "auditSessionId": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "signalPath": {
          "type": "array",
          "items": {
            "enum": [
              "stdin-close",
              "SIGTERM",
              "SIGKILL"
            ]
          }
        },
        "timedOutStages": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": [
              "graceful",
              "terminate",
              "force"
            ]
          }
        },
        "directExit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "code",
            "signal",
            "success"
          ],
          "properties": {
            "success": {
              "type": "boolean"
            },
            "code": {
              "type": "integer"
            },
            "signal": {
              "oneOf": [
                {
                  "type": "null"
                },
                {
                  "type": "string",
                  "minLength": 1
                }
              ]
            }
          }
        },
        "drains": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "stderrCompleted",
            "stdoutCompleted"
          ],
          "properties": {
            "stdoutCompleted": {
              "const": true
            },
            "stderrCompleted": {
              "const": true
            }
          }
        },
        "timings": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "completedAtMs",
            "directExitAtMs",
            "startedAtMs",
            "stdinClosedAtMs",
            "totalMs"
          ],
          "properties": {
            "startedAtMs": {
              "type": "number",
              "minimum": 0
            },
            "stdinClosedAtMs": {
              "type": "number",
              "minimum": 0
            },
            "directExitAtMs": {
              "type": "number",
              "minimum": 0
            },
            "completedAtMs": {
              "type": "number",
              "minimum": 0
            },
            "totalMs": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "remainingPids": {
          "type": "array",
          "maxItems": 0,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "noObservedDescendantsRemain": {
          "const": true
        },
        "containmentCapability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "armedBeforeChildExecution",
            "available",
            "continuouslyTracked",
            "creationEventsCovered",
            "facility",
            "lossDetected",
            "overflowed",
            "reparentingCovered",
            "sessionEscapeCovered",
            "unavailableReason"
          ],
          "properties": {
            "facility": {
              "type": "string",
              "minLength": 1
            },
            "available": {
              "type": "boolean"
            },
            "armedBeforeChildExecution": {
              "type": "boolean"
            },
            "continuouslyTracked": {
              "type": "boolean"
            },
            "creationEventsCovered": {
              "type": "boolean"
            },
            "sessionEscapeCovered": {
              "type": "boolean"
            },
            "reparentingCovered": {
              "type": "boolean"
            },
            "lossDetected": {
              "type": "boolean"
            },
            "overflowed": {
              "type": "boolean"
            },
            "unavailableReason": {
              "$ref": "#/definitions/safeString"
            }
          }
        },
        "escapedDescendantContainmentProven": {
          "type": "boolean"
        },
        "diagnostics": {
          "type": "array",
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "message",
              "nextAction",
              "platform",
              "stage"
            ],
            "properties": {
              "code": {
                "enum": [
                  "CLOSE_FAILED",
                  "CONTAINMENT_UNPROVEN",
                  "DESCENDANT_LEAK",
                  "FORCE_TIMEOUT",
                  "GRACEFUL_SHUTDOWN_TIMEOUT",
                  "PLATFORM_UNSUPPORTED",
                  "STREAM_FAILED",
                  "TERMINATE_TIMEOUT",
                  "TRACKER_LOST",
                  "TRACKER_OVERFLOWED",
                  "TRACKER_UNAVAILABLE",
                  "UNSAFE_PROCESS_GROUP"
                ]
              },
              "stage": {
                "$ref": "#/definitions/safeString"
              },
              "message": {
                "$ref": "#/definitions/safeString"
              },
              "expected": {
                "$ref": "#/definitions/safeValue"
              },
              "observed": {
                "$ref": "#/definitions/safeValue"
              },
              "platform": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "arch",
                  "os"
                ],
                "properties": {
                  "os": {
                    "const": "darwin"
                  },
                  "arch": {
                    "const": "aarch64"
                  }
                }
              },
              "executablePath": {
                "$ref": "#/definitions/safeString"
              },
              "method": {
                "type": "string"
              },
              "requestId": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ]
              },
              "stderr": {
                "$ref": "#/definitions/safeString"
              },
              "nextAction": {
                "$ref": "#/definitions/safeString"
              }
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "escapedDescendantContainmentProven": {
                "const": true
              }
            }
          },
          "then": {
            "properties": {
              "containmentCapability": {
                "properties": {
                  "available": {
                    "const": true
                  },
                  "armedBeforeChildExecution": {
                    "const": true
                  },
                  "continuouslyTracked": {
                    "const": true
                  },
                  "creationEventsCovered": {
                    "const": true
                  },
                  "sessionEscapeCovered": {
                    "const": true
                  },
                  "reparentingCovered": {
                    "const": true
                  },
                  "lossDetected": {
                    "const": false
                  },
                  "overflowed": {
                    "const": false
                  }
                }
              }
            }
          }
        }
      ]
    },
    "acceptanceSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gates",
        "hashes",
        "lifecycle",
        "observationsMs",
        "platform",
        "recordedAt",
        "runId",
        "schemaVersion",
        "shutdown",
        "versions"
      ],
      "properties": {
        "schemaVersion": {
          "const": 1
        },
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "recordedAt": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
        },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "arch",
            "os"
          ],
          "properties": {
            "os": {
              "const": "darwin"
            },
            "arch": {
              "const": "aarch64"
            }
          }
        },
        "versions": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "codex",
            "deno"
          ],
          "properties": {
            "deno": {
              "const": "2.9.3"
            },
            "codex": {
              "const": "0.145.0"
            }
          }
        },
        "hashes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "compatibility",
            "coverage",
            "generatedBundle",
            "transcript"
          ],
          "properties": {
            "compatibility": {
              "$ref": "#/definitions/hash"
            },
            "generatedBundle": {
              "$ref": "#/definitions/hash"
            },
            "coverage": {
              "$ref": "#/definitions/hash"
            },
            "transcript": {
              "$ref": "#/definitions/hash"
            }
          }
        },
        "observationsMs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "initializeToReady",
            "spawnToInitializeResponse",
            "stdinCloseToExit",
            "totalShutdown",
            "turnStartToCompleted",
            "turnStartToFirstEvent"
          ],
          "properties": {
            "spawnToInitializeResponse": {
              "type": "number",
              "minimum": 0
            },
            "initializeToReady": {
              "type": "number",
              "minimum": 0
            },
            "turnStartToFirstEvent": {
              "type": "number",
              "minimum": 0
            },
            "turnStartToCompleted": {
              "type": "number",
              "minimum": 0
            },
            "stdinCloseToExit": {
              "type": "number",
              "minimum": 0
            },
            "totalShutdown": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "completedItems",
            "stderrBytes",
            "stdoutLines",
            "terminalStatus",
            "threadId",
            "turnId"
          ],
          "properties": {
            "stdoutLines": {
              "type": "integer",
              "minimum": 0
            },
            "stderrBytes": {
              "type": "integer",
              "minimum": 0
            },
            "threadId": {
              "type": "string",
              "minLength": 1
            },
            "turnId": {
              "type": "string",
              "minLength": 1
            },
            "terminalStatus": {
              "const": "completed"
            },
            "completedItems": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "shutdown": {
          "$ref": "#/definitions/shutdownEvidence"
        },
        "gates": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authenticatedTurnCompleted",
            "coverageComplete",
            "everyRetainedEnvelopeSchemaValid",
            "exactVersions",
            "generatedArtifactsMatch",
            "lifecycleOrdered",
            "noObservedDescendantsRemain"
          ],
          "properties": {
            "exactVersions": {
              "type": "boolean"
            },
            "generatedArtifactsMatch": {
              "type": "boolean"
            },
            "coverageComplete": {
              "type": "boolean"
            },
            "everyRetainedEnvelopeSchemaValid": {
              "type": "boolean"
            },
            "lifecycleOrdered": {
              "type": "boolean"
            },
            "authenticatedTurnCompleted": {
              "type": "boolean"
            },
            "noObservedDescendantsRemain": {
              "const": true
            }
          }
        }
      }
    }
  }
}

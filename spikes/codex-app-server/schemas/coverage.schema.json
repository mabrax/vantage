{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vantage.local/schemas/codex-app-server-coverage-v1.json",
  "title": "Codex app-server stable protocol coverage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "codexVersion",
    "generatorMode",
    "generatedBundleSha256",
    "entries"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "codexVersion": {
      "const": "0.145.0"
    },
    "generatorMode": {
      "const": "stable"
    },
    "generatedBundleSha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "direction",
          "method",
          "disposition",
          "rationale",
          "observedCount"
        ],
        "properties": {
          "direction": {
            "enum": [
              "client-request",
              "client-notification",
              "server-notification",
              "server-request"
            ]
          },
          "method": {
            "type": "string",
            "minLength": 1
          },
          "disposition": {
            "enum": [
              "exercised",
              "schema-validated-unexercised",
              "intentionally-ignored",
              "unsupported"
            ]
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "pattern": ".*\\S.*"
          },
          "observedCount": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}

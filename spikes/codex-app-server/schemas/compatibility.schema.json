{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vantage.local/schemas/codex-app-server-compatibility-v1.json",
  "title": "Codex app-server compatibility manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deno",
    "codex",
    "generation",
    "validationPlatform",
    "limits"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "deno": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version"],
      "properties": {
        "version": {
          "const": "2.9.3"
        }
      }
    },
    "codex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cliVersion", "versionOutput", "appServerArgs"],
      "properties": {
        "cliVersion": {
          "const": "0.145.0"
        },
        "versionOutput": {
          "const": "codex-cli 0.145.0"
        },
        "appServerArgs": {
          "const": ["app-server", "--stdio"]
        }
      }
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "typesCommand",
        "jsonSchemaCommand",
        "generatedRoot",
        "bundleSha256"
      ],
      "properties": {
        "mode": {
          "const": "stable"
        },
        "typesCommand": {
          "const": ["app-server", "generate-ts", "--out", "{output}"]
        },
        "jsonSchemaCommand": {
          "const": [
            "app-server",
            "generate-json-schema",
            "--out",
            "{output}"
          ]
        },
        "generatedRoot": {
          "type": "string",
          "const": "spikes/codex-app-server/generated/0.145.0",
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "bundleSha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "validationPlatform": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch", "cleanupStrategy"],
      "properties": {
        "os": {
          "const": "darwin"
        },
        "arch": {
          "const": "aarch64"
        },
        "cleanupStrategy": {
          "const": "unix-process-group-v1"
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxStdoutLineBytes",
        "maxStderrBytes",
        "maxQueueMessages",
        "maxQueueBytes",
        "maxModelPages",
        "initializeMs",
        "modelCatalogMs",
        "firstTurnEventMs",
        "turnCompletionMs",
        "gracefulExitMs",
        "terminateExitMs",
        "forceExitMs"
      ],
      "properties": {
        "maxStdoutLineBytes": {
          "$ref": "#/definitions/positiveInteger"
        },
        "maxStderrBytes": {
          "$ref": "#/definitions/positiveInteger"
        },
        "maxQueueMessages": {
          "$ref": "#/definitions/positiveInteger"
        },
        "maxQueueBytes": {
          "$ref": "#/definitions/positiveInteger"
        },
        "maxModelPages": {
          "$ref": "#/definitions/positiveInteger"
        },
        "initializeMs": {
          "$ref": "#/definitions/positiveInteger"
        },
        "modelCatalogMs": {
          "$ref": "#/definitions/positiveInteger"
        },
        "firstTurnEventMs": {
          "$ref": "#/definitions/positiveInteger"
        },
        "turnCompletionMs": {
          "$ref": "#/definitions/positiveInteger"
        },
        "gracefulExitMs": {
          "$ref": "#/definitions/positiveInteger"
        },
        "terminateExitMs": {
          "$ref": "#/definitions/positiveInteger"
        },
        "forceExitMs": {
          "$ref": "#/definitions/positiveInteger"
        }
      }
    }
  },
  "definitions": {
    "positiveInteger": {
      "type": "integer",
      "minimum": 1
    }
  }
}
